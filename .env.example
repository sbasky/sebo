# Your site as registered in Google Search Console.
# Domain property:     sc-domain:example.com
# URL-prefix property:  https://example.com/
SITE_URL=sc-domain:example.com

# Where the weekly brief gets sent.
USER_EMAIL=you@example.com

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — https://resend.com
RESEND_API_KEY=re_...

# Sender address. Must be a verified domain in Resend.
# Leave the default to use Resend's sandbox sender (only delivers
# to your own Resend account email until you verify a domain).
RESEND_FROM_EMAIL=Sebo <onboarding@resend.dev>
